# Plantilla de variables de entorno del backend.
# Copiá este archivo a `.env` y completá los valores reales.
# `.env` está en .gitignore y NO se sube al repo.

# === SMTP ===
# Gmail:      MAIL_HOST=smtp.gmail.com  MAIL_PORT=587  (requiere App Password)
# MailerSend: MAIL_HOST=smtp.mailersend.net  MAIL_PORT=587
#   OJO: en el trial, MAIL_FROM debe ser @<tu-dominio>.mlsender.net
#   y solo se puede enviar al email administrador de la cuenta MailerSend.
MAIL_HOST=smtp.mailersend.net
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@tu-dominio.mlsender.net

# === Google OAuth ===
GOOGLE_OAUTH_CLIENT_ID=

# === JWT ===
JWT_SECRET=cambia-esta-clave-por-una-larga-y-secreta
